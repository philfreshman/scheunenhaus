            "mainEntity": [
                {
                    "@type": "Question",
                    "name": "Wie weit ist das Scheunenhaus am See von Berlin entfernt?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Das Scheunenhaus am See liegt etwa 110 km vom Berliner Zentrum entfernt in der Uckermark, Brandenburg. Die Fahrt dauert ca. 1,5 Stunden."
                    }
                },
                {
                    "@type": "Question",
                    "name": "Für wie viele Personen ist das Ferienhaus geeignet?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Das Ferienhaus bietet Platz für bis zu 10 Erwachsene plus Kinder. Es verfügt über 5 Zimmer und ist ideal für Familien, Freunde oder Kollegen."
                    }
                },
                {
                    "@type": "Question",
                    "name": "Gibt es einen Badesee in der Nähe?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Ja, ein Badesee ist in fußläufiger Nähe erreichbar. Die nächstgelegene Badestelle ist nur etwa 5 Gehminuten entfernt."
                    }
                },
                {
                    "@type": "Question",
                    "name": "Sind Haustiere im Ferienhaus erlaubt?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Nein, Haustiere sind im Scheunenhaus am See nicht erlaubt."
                    }
                },
                {
                    "@type": "Question",
                    "name": "Welche Ausstattung bietet das Ferienhaus?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Das Ferienhaus verfügt über eine hochwertig ausgestattete Küche, Kamin, WLAN, Terrasse, Parkplatz und einen 5000m² großen Naturgarten. Es wurde mit natürlichen Materialien nachhaltig konzipiert."
                    }
                },
                {
                    "@type": "Question",
                    "name": "Ist WLAN verfügbar?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Ja, WLAN ist im Ferienhaus verfügbar."
                    }
                },
                {
                    "@type": "Question",
                    "name": "Gibt es Parkmöglichkeiten?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Ja, Parkplätze sind direkt am Ferienhaus vorhanden."
                    }
                },
                {
                    "@type": "Question",
                    "name": "Was macht das Scheunenhaus ökologisch?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Das Ferienhaus wurde nachhaltig konzipiert mit großem Wert auf natürliche Materialien. Die Innenarchitektur greift traditionelle Scheunenstrukturen mit offenen Räumen, Schlafgalerien und Holzdecken auf."
                    }
                },
