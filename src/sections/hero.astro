---
import { Image } from "astro:assets"
import heroImg from "../assets/img/Startbild.webp"
import Section from "../components/Section.astro"
import { SECTIONS } from "../utils/constants"
---
<style is:global>
    #hero {
        height: 100dvh;
        overflow: hidden; /* Prevents scaled image from expanding the page */
        position: relative;
    }
    #hero-img {
        width: 100%;
        animation: fadeInImage 1.2s ease-out forwards;

        object-fit: cover;
        object-position: center;
        height: 100%;
        position: absolute;

        top: 0;
        left: 0;

        opacity: 0;
        transform: scale(1.05); /* Start smaller instead of larger */
    }
    @keyframes fadeInImage {
        to {
            opacity: 1;
            transform: scale(1);
        }
    }


    @keyframes fadeInUp {
        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    #heading {
        position: relative;
        z-index: 1;
        width: 100%;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        font-size: 1.8rem;
        letter-spacing: 13px;
    }

    .hero-title {
        /* Responsive base */
        font-size: 2.2rem;
        letter-spacing: 0.3em;

        font-family: 'AmaticSC', sans-serif;
        font-weight: bold;
        line-height: 1.3;
        text-align: center;

        margin: 0;
        display: flex;
        flex-direction: column;
        user-select: none;

        /* Transition effect */
        opacity: 0;
        animation: fadeInUp 1.2s ease-out forwards;
        animation-delay: 0.2s; /* starts after a short delay */
    }

    @media (min-width: 440px) {
        .hero-title {
            font-size: 2.4rem;
        }
    }

    @media (min-width: 640px) {
        .hero-title {
            font-size: 2.6rem;
        }
    }

    @media (min-width: 768px) {
        .hero-title {
            font-size: 2.8rem;
        }
    }

    @media (min-width: 1024px) {
        .hero-title {
            font-size: 2.9rem;
        }
    }

    @media (min-width: 1500px) {
        .hero-title {
            font-size: 3rem;
        }
    }
</style>
<Section id={SECTIONS.hero}>
    <div id="heading">
        <h1 class="hero-title">
            <span>SCHEUNENHAUS</span>
            <span>AM SEE</span>
        </h1>
    </div>

    <Image
        id="hero-img"
        src={heroImg}
        alt="Scheunenhaus am See - Beautiful lake house view"
        format="webp"
        quality={90}
        widths={[1600, 1920, heroImg.width]}
        sizes="100vw"
        loading="eager"
        decoding="sync"
        fetchpriority="high"
        onload="document.body.classList.remove('hidden')"
    />
</Section>