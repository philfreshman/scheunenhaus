---
import { Image } from "astro:assets"
import heroImg from "../assets/img/Startbild.webp"
import { SECTIONS } from "../utils/constants"
---
<style>
    #hero {
        height: 100%;
    }
    #hero-img {
        object-fit: cover;
        object-position: center;
        width: 100%;
        height: 100%;
        position: absolute;
        top: 0;
        left: 0;

        /* Transition effect */
        opacity: 0;
        transform: scale(1.05); /* slight zoom for a nicer effect */
        animation: fadeInImage 1.2s ease-out forwards;
    }
    @keyframes fadeInImage {
        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    .hero-title {
        font-family: 'AmaticSC', sans-serif;
        font-weight: bold;
        line-height: 1.3;
        text-align: center;
        font-size: 3rem;
        margin: 0;
        display: flex;
        flex-direction: column;
        user-select: none;

        /* Transition effect */
        opacity: 0;
        //transform: translateY(10px);
        animation: fadeInUp 1.2s ease-out forwards;
        animation-delay: 0.2s; /* starts after a short delay */
    }
    @keyframes fadeInUp {
        to {
            opacity: 1;
            transform: scale(1);

        }
    }

    #heading {
        position: relative;
        z-index: 1;
        width: 100%;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
    }
    @media (max-width: 360px) {
        #heading {
            font-size: 1.8rem;
            letter-spacing: 13px;
        }
    }
    @media (min-width: 351px) and (max-width: 380px) {
        #heading {
            font-size: 2.1rem;
            letter-spacing: 14px;
        }
    }
    @media (min-width: 381px) and (max-width: 1300px) {
        #heading {
            font-size: 2.7rem;
            letter-spacing: 14px;
        }
    }
    @media (min-width: 1301px) and (max-width: 1499px) {
        #heading {
            font-size: 2.9rem;
            letter-spacing: 16px;
        }
    }
    @media (min-width: 1500px) {
        #heading {
            font-size: 3rem;
            letter-spacing: 17px;
        }
    }
</style>
<section id={SECTIONS.hero}>
    <div id="heading">
        <h1 class="hero-title">
            <span>SCHEUNENHAUS</span>
            <span>AM SEE</span>
        </h1>
    </div>
    <Image
        id="hero-img"
        src={heroImg}
        alt="Scheunenhaus am See - Beautiful lake house view"
        format="webp"
        quality={90}
        widths={[400, 800, 1200, 1600, 1920, heroImg.width]}
        sizes="100vw"
        loading="eager"
        decoding="sync"
        fetchpriority="high"
        onload="document.body.classList.remove('hidden')"
    />
</section>