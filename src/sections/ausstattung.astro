---
import { frontmatter as markdown } from "../content/de/furnishing.md"
import { SECTIONS } from "../utils/constants"
---
<style>
    #ausstattung {
    }
    @media (max-width: 699px) {
        #ausstattung {
            padding-left: 1%;
            padding-right: 1%;
        }
    }
    @media (min-width: 700px) and (max-width: 1299px) {
        #ausstattung {
            padding-left: 8%;
            padding-right: 8%;
        }
    }
    @media (min-width: 1300px) and (max-width: 1499px) {
        #ausstattung {
            padding-left: 12%;
            padding-right: 12%;
        }
    }
    @media (min-width: 1500px) {
        #ausstattung {
            padding-left: 16%;
            padding-right: 16%;
        }
    }
</style>

<section id={SECTIONS.furnishing}>
    <div class="section-header">
        <h4 set:html={markdown.header} />
    </div>
    <div class="section-content">
        <p set:html={markdown.content} />
    </div>
</section>
