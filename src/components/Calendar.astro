<style is:global>
    #calendar {
        height: 100%;
        width: 100%;
        font-family: "Raleway", sans-serif;
        background: var(--primary-background);
    }

    .hidden{
        visibility: hidden;
    }

    .fc {
        gap: 1em;
    }

    .fc-header-toolbar {
        height: 38px;
    }

    .fc-toolbar-title {
        font-size: 17px;
    }

    .fc-button-primary {
        background: unset;
        border: unset;
        color: black;
    }

    .fc-button-primary:hover {
        background: #e0dedd;
        color: black;
    }

    .fc-button-primary:not(:disabled):active {
        background: #e0dedd;
        box-shadow: unset;
        color: black;
    }

    .fc-button-primary:focus {
        box-shadow: unset;
    }

    .fc-daygrid-day.fc-day-today {
        background: unset;
        text-decoration: underline;
    }

    .fc-day-disabled {
        background: var(--striped-background);
        box-shadow: inset 0 0 0 2px rgba(230, 228, 226, 0.5);
    }

    @media (max-width: 599px) {
        #calendar {
            padding-left: 0;
            padding-right: 0;
        }
    }
    @media (min-width: 600px) and (max-width: 879px) {
        #calendar {
            padding-left: 1%;
            padding-right: 1%;
        }
    }
    @media (min-width: 880px) and (max-width: 1299px) {
        #calendar {
            padding-left: 8%;
            padding-right: 8%;
        }
    }
    @media (min-width: 1300px) and (max-width: 1649px) {
        #calendar {
            padding-left: 12%;
            padding-right: 12%;
        }
    }
    @media (min-width: 1650px) {
        #calendar {
            padding-left: 14%;
            padding-right: 14%;
        }
    }
</style>

<div id='calendar' class="hidden"/>

<script>
    import { Calendar } from '@fullcalendar/core';
    import dayGridPlugin from '@fullcalendar/daygrid';
    import timeGridPlugin from '@fullcalendar/timegrid';
    import listPlugin from '@fullcalendar/list';
    import googleCalendar from '@fullcalendar/google-calendar';

    const calendarEl = document.getElementById('calendar');
    if(!calendarEl) throw new Error('Could not find calendar element');

    const calendar = new Calendar(calendarEl, {
        plugins: [ dayGridPlugin, timeGridPlugin, listPlugin, googleCalendar ],
        initialView: 'dayGridMonth',
        headerToolbar: {
            left: 'prev',
            center: 'title',
            right: 'next'
        },
        editable: false,
        selectable: false,
        nowIndicator: true,
        googleCalendarApiKey: import.meta.env.PUBLIC_GOOGLE_CALENDAR_API_KEY,
        eventSources: [
            {googleCalendarId: import.meta.env.PUBLIC_GOOGLE_CALENDAR_ID_1},
            {googleCalendarId: import.meta.env.PUBLIC_GOOGLE_CALENDAR_ID_2}
        ],
        eventColor: "#aaaaa7",
        eventContent: "Belegt",
        firstDay: 1,
        locale: 'de',
        aspectRatio: 1.5,
        showNonCurrentDates: false,
        eventOrder: "allDay",
        // Kills calendar interactivity
        eventDidMount(info) {
            const el = info.el;
            if (el.tagName === 'A') {
                el.removeAttribute('href');
                el.removeAttribute('target');
                el.style.cursor = 'default';
            } else {
                const a = el.querySelector('a[href]');
                if (a instanceof HTMLAnchorElement) {
                    a.removeAttribute('href');
                    a.removeAttribute('target');
                    a.style.cursor = 'default';
                }
            }
        },
      loading(isLoading) {
          if (!isLoading) {
              const container = calendarEl.closest('#calendar-stripes');
              if (container) {
                  container.classList.remove('loading-stripes-animation');
                  calendarEl.classList.remove('hidden')
              }
          }
      }
    });

    calendar.render();
</script>
