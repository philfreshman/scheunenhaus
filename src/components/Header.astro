---
import { SECTIONS } from "../utils/constants"
---
<style>
    @media screen and (max-width: 999px) {
        header {
            display: none !important;
        }
    }

    header {
        width: 100%;
        height: 60px;
        display: flex;
        justify-content: center;
        align-items: center;
        position: fixed;
        top: 0;
        transition: bottom 0.7s;
        gap: 1.5vw;
        z-index: 5;
    }

    header a {
        margin-block-start: 0.83em;
        margin-block-end: 0.83em;
        margin-inline-start: 0;
        margin-inline-end: 0;
        font-size: 0.8em;
        letter-spacing: 2px;
        display: block;
        color: black;
    }
    header a:visited {
        color: black;
    }
    header a:link {
        color: black;
        text-decoration: none;
    }
    link {
        padding: 1.5px;
    }
</style>

<header>
    <a class="link" href={SECTIONS.house}>DAS HAUS</a>
    <a class="link" href={SECTIONS.furnishing}>AUSSTATTUNG</a>
    <a class="link" href={SECTIONS.floorPlan}>GRUNDRISS</a>
    <a class="link" href={SECTIONS.price}>PREISE</a>
    <a class="link" href={SECTIONS.occupancy}>BELEGUNG</a>
    <a class="link" href={SECTIONS.contact}>KONTAKT</a>
    <a
        aria-label="Facebook"
        style="padding: 1.5px"
        href="https://www.facebook.com/Scheunenhaus-am-See-423332671778636"
        target="_blank"
    >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
            <title>Facebook</title>
            <path d="M9 8H6v4h3v12h5V12h3.642L18 8h-4V6.333C14 5.378 14.192 5 15.115 5H18V0h-3.808C10.596 0 9 1.583 9 4.615z" />
        </svg>
    </a>
    <a
        aria-label="instagram-link"
        style="padding: 1.5px"
        href="https://www.instagram.com/das_scheunenhaus/"
        target="_blank"
    >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
            <title>Instagram</title>
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849s-.012 3.584-.069 4.849c-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849s.013-3.583.07-4.849c.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069M12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12s.014 3.668.072 4.948c.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24s3.668-.014 4.948-.072c4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948s-.014-3.667-.072-4.947c-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0m0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324M12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8m6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881"></path>
        </svg>
    </a>
</header>

<script>
    const links = document.querySelectorAll<HTMLAnchorElement>('.link');
    const header = document.getElementsByTagName('header')[0];

    function updateFont() {
        const currentHash = window.location.hash;
        links.forEach((link) => {
            if (link.getAttribute('href') === currentHash) {
                link.classList.add("active-link")
            } else {
                link.classList.remove("active-link")
            }
        });
    }

    function setHeaderBackground() {
        if (document.documentElement.scrollTop > 70 || document.body.scrollTop > 70) {
            header.style.backgroundColor = getComputedStyle(document.documentElement).getPropertyValue('--primary-background').trim();

        } else {
            header.style.backgroundColor = 'transparent';
        }
    }

    // Function to scroll to the target section
    function scrollToSection(hash: string) {
        const section = document.querySelector(hash);
        if (section) {
            section.scrollIntoView({ behavior: 'smooth' });
        }
    }

    window.addEventListener('load', () => {
        const hash = window.location.hash;
        if (hash) {
            scrollToSection(hash);
        }

        // Update fonts and header background after everything is loaded.
        updateFont();
        setHeaderBackground();
    });

    window.addEventListener('hashchange', updateFont);
    window.addEventListener('scroll', setHeaderBackground);
</script>
