---
import { SECTIONS } from "../utils/constants"
---
<style>
    @media screen and (max-width: 999px) {
        header {
            display: none !important;
        }
    }

    header {
        width: 100%;
        height: 60px;
        display: flex;
        justify-content: center;
        align-items: center;
        position: fixed;
        top: 0;
        transition: bottom 0.7s;
        gap: 1.5vw;
        z-index: 5;
    }

    header a {
        margin-block-start: 0.83em;
        margin-block-end: 0.83em;
        margin-inline-start: 0;
        margin-inline-end: 0;
        font-size: 0.8em;
        letter-spacing: 2px;
        display: block;
        color: black;
    }
    header a:visited {
        color: black;
    }
    header a:link {
        color: black;
        text-decoration: none;
    }
    link {
        padding: 1.5px;
    }
</style>

<header>
    <a class="link" href=`#${SECTIONS.house}`>DAS HAUS</a>
    <a class="link" href=`#${SECTIONS.furnishing}`>AUSSTATTUNG</a>
    <a class="link" href=`#${SECTIONS.floorPlan}`>GRUNDRISS</a>
    <a class="link" href=`#${SECTIONS.price}`>PREISE</a>
    <a class="link" href=`#${SECTIONS.occupancy}`>BELEGUNG</a>
    <a class="link" href=`#${SECTIONS.contact}`>KONTAKT</a>
    <a
        aria-label="facebook-link"
        style="padding: 1.5px"
        href="https://www.facebook.com/Scheunenhaus-am-See-423332671778636"
        target="_blank"
    >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24">
            <path
                d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"
            ></path>
        </svg>
    </a>
    <a
        aria-label="instagram-link"
        style="padding: 1.5px"
        href="https://www.instagram.com/das_scheunenhaus/"
        target="_blank"
    >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24">
            <path
                d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
            ></path>
        </svg>
    </a>
</header>

<script>
    const links = document.querySelectorAll<HTMLAnchorElement>('.link');
    const header = document.getElementsByTagName('header')[0];

    function updateFont() {
        const currentHash = window.location.hash;
        links.forEach((link) => {
            if (link.getAttribute('href') === currentHash) {
                link.classList.add("active-link")
            } else {
                link.classList.remove("active-link")
            }
        });
    }

    function setHeaderBackground() {
        if (document.documentElement.scrollTop > 70 || document.body.scrollTop > 70) {
            header.style.backgroundColor = getComputedStyle(document.documentElement).getPropertyValue('--primary-background').trim();

        } else {
            header.style.backgroundColor = 'transparent';
        }
    }

    // Function to scroll to the target section
    function scrollToSection(hash: string) {
        const section = document.querySelector(hash);
        if (section) {
            section.scrollIntoView({ behavior: 'smooth' });
        }
    }

    window.addEventListener('load', () => {
        const hash = window.location.hash;
        if (hash) {
            scrollToSection(hash);
        }

        // Update fonts and header background after everything is loaded.
        updateFont();
        setHeaderBackground();
    });

    window.addEventListener('hashchange', updateFont);
    window.addEventListener('scroll', setHeaderBackground);
</script>
