---
interface Props {
    title?: string
    description?: string
}

const siteTitle = "Scheunenhaus am See"
const defaultDescription =
    "Ferienhaus für 10 Personen in der Uckermark. Ökologisches Scheunenhaus am See mit 5000m² Naturgarten, 110km von Berlin. Perfekt für Familien & Gruppen."

const { title = siteTitle, description = defaultDescription } = Astro.props

// Create SEO-optimized title with site name
const pageTitle = title === siteTitle ? title : `${title} | ${siteTitle}`
const canonicalURL = new URL(Astro.url.pathname, Astro.site)
---

<head>
    <!-- Primary Meta Tags -->
    <title>{pageTitle}</title>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="author" content="Kasia Swiezak & Marius Bell" />
    <meta name="copyright" content={`© ${new Date().getFullYear()} Kasia Swiezak & Marius Bell GbR`} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image" content={new URL('/og-image.png', Astro.site)} />
    <meta property="og:image:alt" content="Scenic view of Scheunenhaus am See" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:site_name" content="Scheunenhaus am See" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL('/og-image.png', Astro.site)} />
    <meta name="twitter:image:alt" content="Scenic view of Scheunenhaus am See" />


    <!-- Geo Tags -->
    <meta name="geo.region" content="DE-BB" />
    <meta name="geo.placename" content="Bertikow, Uckermark" />
    <meta name="geo.position" content="53.24704359349119;13.935297047810293" />
    <meta name="ICBM" content="53.24704359349119, 13.935297047810293" />

    <!-- Structured Data -->
    <script type="application/ld+json" src="/structured-data.json" is:inline/>

    <link rel="preload" href="/fonts/amatic-sc.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/raleway.woff2" as="font" type="font/woff2" crossorigin />
    <style>
        @font-face {
            font-family: 'AmaticSC';
            src: url('/fonts/amatic-sc.woff2') format('woff2');
            font-display: block;
        }
        @font-face {
            font-family: 'Raleway';
            src: url('/fonts/raleway.woff2') format('woff2');
            font-display: block;
        }
    </style>

    <!-- Favicon and Touch Icons -->
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <!-- Android Chrome Icons -->
    <link rel="icon" type="image/png" sizes="192x192" href="/android-chrome-192x192.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/android-chrome-512x512.png" />
    <!-- Web App Manifest -->
    <link rel="manifest" href="/site.webmanifest" />
</head>

<!-- Google tag (gtag.js) -->
<script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-TRZ9X6L0SF"></script>
<script>
    // @ts-nocheck
    // biome-ignore-start lint: google stuff
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());

    gtag('config', 'G-TRZ9X6L0SF');
    // biome-ignore-end lint: google stuff
</script>

